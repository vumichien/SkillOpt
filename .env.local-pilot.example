# Copy to .env.local-pilot and fill in your DeepSeek key. NEVER commit the real file.
# The launch scripts (run_local_pilot.ps1 / .sh) source .env.local-pilot if present.

# --- Optimizer: DeepSeek (cloud, OpenAI-compatible) ---
OPTIMIZER_OPENAI_BASE_URL=https://api.deepseek.com/v1
OPTIMIZER_OPENAI_API_KEY=sk-REPLACE_ME

# --- Target: local Qwen2.5-7B via Ollama (OpenAI-compatible /v1) ---
QWEN_CHAT_BASE_URL=http://localhost:11434/v1
QWEN_CHAT_API_KEY=ollama
TARGET_DEPLOYMENT=qwen2.5:7b-instruct-q4_K_M
QWEN_CHAT_ENABLE_THINKING=false
QWEN_CHAT_TEMPERATURE=0           # deterministic decoding -> reliable gate signal on small eval splits
